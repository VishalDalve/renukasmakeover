---
// Auto-advancing hero slider. Slides sit side-by-side on a flex track that
// translates left/right (a real "slide", not a fade) — plus prev/next arrows
// and dot indicators for manual control. Pass real `src` values once photos
// exist in /public/images; until then each slide shows a labeled placeholder.
import PhotoBox from "./PhotoBox.astro";

interface Slide {
  src?: string;
  alt: string;
  label: string;
}

interface Props {
  slides: Slide[];
  intervalMs?: number;
}

const { slides, intervalMs = 3000 } = Astro.props;
---

<div class="hero-slideshow" data-interval={intervalMs} data-count={slides.length}>
  <div class="hero-track">
    {slides.map((slide, i) => (
      <div class="hero-slide" data-index={i}>
        <PhotoBox
          src={slide.src}
          alt={slide.alt}
          label={slide.label}
          ratio="16/9"
          eager={i === 0}
          class="hero-slide-photo"
        />
      </div>
    ))}
  </div>

  <button class="hero-arrow hero-arrow--prev" type="button" aria-label="Previous slide">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <button class="hero-arrow hero-arrow--next" type="button" aria-label="Next slide">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>

  <div class="hero-dots">
    {slides.map((_, i) => (
      <button class:list={["hero-dot", { "is-active": i === 0 }]} data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
    ))}
  </div>
</div>

<script>
  function initHeroSlideshow(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>(".hero-track");
    const slides = Array.from(root.querySelectorAll<HTMLElement>(".hero-slide"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>(".hero-dot"));
    const prevBtn = root.querySelector<HTMLButtonElement>(".hero-arrow--prev");
    const nextBtn = root.querySelector<HTMLButtonElement>(".hero-arrow--next");
    const count = slides.length;
    const interval = Number(root.dataset.interval) || 3000;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!track || count === 0) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const render = () => {
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => dot.classList.toggle("is-active", i === current));
      slides.forEach((slide, i) => slide.classList.toggle("is-active", i === current));
    };

    const goTo = (index: number) => {
      current = ((index % count) + count) % count;
      render();
    };

    const next = () => goTo(current + 1);
    const prev = () => goTo(current - 1);

    const stop = () => {
      if (timer) clearInterval(timer);
      timer = undefined;
    };

    const start = () => {
      stop();
      if (reduceMotion || count <= 1) return;
      timer = setInterval(next, interval);
    };

    // Any manual interaction restarts the auto-play timer from zero,
    // so it doesn't jump again right after the user just clicked.
    const manual = (action: () => void) => {
      action();
      start();
    };

    prevBtn?.addEventListener("click", () => manual(prev));
    nextBtn?.addEventListener("click", () => manual(next));
    dots.forEach((dot) => {
      dot.addEventListener("click", () => manual(() => goTo(Number(dot.dataset.index))));
    });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    render();
    start();
  }

  document.querySelectorAll<HTMLElement>(".hero-slideshow").forEach(initHeroSlideshow);
</script>

<style>
  .hero-slideshow {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.9s cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .hero-slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
  }

  .hero-slide :global(.hero-slide-photo) {
    height: 100%;
    aspect-ratio: auto !important;
    border-radius: 0;
  }
  .hero-slide :global(.hero-slide-photo img),
  .hero-slide :global(.hero-slide-photo .photo-box__placeholder) {
    height: 100%;
    border: none;
  }
  .hero-slide.is-active :global(.hero-slide-photo img),
  .hero-slide.is-active :global(.hero-slide-photo .photo-box__placeholder) {
    animation: hero-kenburns 7s ease-in-out forwards;
  }

  @keyframes hero-kenburns {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }

  .hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(250, 246, 240, 0.5);
    background: rgba(42, 36, 32, 0.35);
    color: var(--color-ivory);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .hero-arrow:hover { background: rgba(42, 36, 32, 0.6); border-color: var(--color-ivory); }
  .hero-arrow--prev { left: var(--space-2); }
  .hero-arrow--next { right: var(--space-2); }

  @media (min-width: 640px) {
    .hero-arrow--prev { left: var(--space-3); }
    .hero-arrow--next { right: var(--space-3); }
  }

  .hero-dots {
    position: absolute;
    bottom: var(--space-2);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.5rem;
  }
  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--color-ivory);
    background: transparent;
    padding: 0;
    cursor: pointer;
  }
  .hero-dot.is-active { background: var(--color-ivory); }

  @media (prefers-reduced-motion: reduce) {
    .hero-track { transition: none; }
    .hero-slide.is-active :global(.hero-slide-photo img),
    .hero-slide.is-active :global(.hero-slide-photo .photo-box__placeholder) {
      animation: none;
    }
  }
</style>
