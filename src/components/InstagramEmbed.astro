---
interface Props {
  url: string;
  class?: string;
}

const { url, class: className } = Astro.props as Props;
---

<blockquote
  class:list={["instagram-media", className]}
  data-instgrm-permalink={url}
  data-instgrm-version="14"
  style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin:1px; max-width:400px; min-width:326px; padding:0; width:99.375%;"
>
  <a href={url} target="_blank" rel="noopener noreferrer">View this post on Instagram</a>
</blockquote>
