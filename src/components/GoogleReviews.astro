---
// Live reviews come from the Google Places API (Place Details -> reviews) when
// GOOGLE_PLACES_API_KEY / GOOGLE_PLACE_ID are set — see SETUP.md. Google's API
// caps this at 5 reviews per place; there is no official way to paginate past
// that. To show more than 5 with a working "View More", add extra reviews to
// src/data/reviews.json — they render after the live ones, no code changes needed.
import curated from "../data/reviews.json";

const apiKey = import.meta.env.GOOGLE_PLACES_API_KEY;
const placeId = import.meta.env.GOOGLE_PLACE_ID;

type Review = { author_name: string; rating: number; text: string; relative_time_description: string };

let liveReviews: Review[] = [];
let rating: number | null = null;
let totalReviews = 0;
let isLive = false;

if (apiKey && placeId) {
  try {
    const res = await fetch(
      `https://maps.googleapis.com/maps/api/place/details/json?place_id=${placeId}&fields=rating,user_ratings_total,reviews&key=${apiKey}`
    );
    if (res.ok) {
      const data = await res.json();
      if (data.status === "OK") {
        rating = data.result.rating ?? null;
        totalReviews = data.result.user_ratings_total ?? 0;
        liveReviews = data.result.reviews ?? [];
        isLive = true;
      }
    }
  } catch {
    // Fall through to curated-only.
  }
}

const curatedReviews: Review[] = (curated.reviews ?? []).map((r) => ({
  author_name: r.author,
  rating: r.rating,
  text: r.text,
  relative_time_description: r.time,
}));

const allReviews = [...liveReviews, ...curatedReviews];
const PAGE_SIZE = 3;
---

<section class="reviews">
  <div class="container">
    <span class="eyebrow">Client Love</span>
    <h2>{isLive && rating ? `${rating.toFixed(1)} ★ from ${totalReviews} Google reviews` : "What Clients Say"}</h2>
    {!isLive && (
      <p class="reviews-note">
        Live Google rating connects once the Places API is configured — see <code>SETUP.md</code>.
      </p>
    )}

    <div class="grid grid-3 reviews-grid" data-page-size={PAGE_SIZE}>
      {allReviews.map((review, i) => (
        <blockquote class="card review-card fade-in" data-index={i} style={i >= PAGE_SIZE ? "display:none" : undefined}>
          <p class="stars">{"★".repeat(review.rating)}{"☆".repeat(5 - review.rating)}</p>
          <p>&ldquo;{review.text}&rdquo;</p>
          <footer>
            <strong>{review.author_name}</strong>
            <span class="review-time">{review.relative_time_description}</span>
          </footer>
        </blockquote>
      ))}
    </div>

    {allReviews.length > PAGE_SIZE && (
      <button class="btn btn-outline reviews-more" type="button">View More</button>
    )}
  </div>
</section>

<script>
  function initReviews(section: HTMLElement) {
    const grid = section.querySelector<HTMLElement>(".reviews-grid");
    const button = section.querySelector<HTMLButtonElement>(".reviews-more");
    if (!grid || !button) return;

    const pageSize = Number(grid.dataset.pageSize) || 3;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>(".review-card"));
    let shown = pageSize;

    button.addEventListener("click", () => {
      cards.slice(shown, shown + pageSize).forEach((card) => (card.style.display = ""));
      shown += pageSize;
      if (shown >= cards.length) button.remove();
    });
  }

  document.querySelectorAll<HTMLElement>(".reviews").forEach(initReviews);
</script>

<style>
  .review-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .stars { color: var(--color-gold); letter-spacing: 0.1em; margin: 0; }
  .review-card footer { display: flex; justify-content: space-between; font-size: 0.85rem; margin-top: auto; }
  .review-time { opacity: 0.6; }
  .reviews-note { font-size: 0.85rem; opacity: 0.65; }
  .reviews-more { margin-top: var(--space-3); }
</style>
