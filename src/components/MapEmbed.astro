---
// Uses PUBLIC_GOOGLE_MAPS_EMBED_KEY (client-safe, restrict it to Maps Embed API +
// your domain in Google Cloud Console). Falls back to a static-style placeholder
// with a "get directions" link when the key isn't set yet — see SETUP.md.
import { site } from "../data/site";

const mapsKey = import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED_KEY;
const query = encodeURIComponent(
  `${site.address.line1}, ${site.address.locality}, ${site.address.city}, ${site.address.state}`
);
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${query}`;
---

<section class="map-section">
  <div class="container">
    <span class="eyebrow">Find Us</span>
    <h2>Studio Location</h2>

    {mapsKey ? (
      <iframe
        class="map-frame"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        src={`https://www.google.com/maps/embed/v1/place?key=${mapsKey}&q=${query}`}
        allowfullscreen
      ></iframe>
    ) : (
      <div class="map-placeholder">
        <p>Map embed connects once <code>PUBLIC_GOOGLE_MAPS_EMBED_KEY</code> is set — see <code>SETUP.md</code>.</p>
        <a class="btn btn-outline" href={directionsUrl} target="_blank" rel="noopener noreferrer">
          Get Directions
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .map-frame {
    width: 100%;
    height: 360px;
    border: 0;
  }
  .map-placeholder {
    height: 360px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: #fff;
    border: 1px dashed rgba(42, 36, 32, 0.15);
    text-align: center;
    padding: var(--space-3);
  }
</style>
