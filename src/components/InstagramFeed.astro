---
// Renders live Instagram embeds (reels + posts) sourced from src/data/instagram.json.
// To add/remove/reorder posts for any page, edit that JSON file only — no component changes needed.
import { site } from "../data/site";
import InstagramEmbed from "./InstagramEmbed.astro";
import instagramData from "../data/instagram.json";

interface Props {
  page: string;
}

const { page } = Astro.props as Props;

const entry = (instagramData as Record<string, { videos?: { url: string }[]; images?: { url: string }[] }>)[page] ?? {};
const videos = entry.videos ?? [];
const images = entry.images ?? [];
---

{(videos.length > 0 || images.length > 0) && (
  <section class="instagram">
    <div class="container">
      <span class="eyebrow">Follow Along</span>
      <h2>@{site.instagramHandle}</h2>

      {videos.length > 0 && (
        <>
          <h3 class="ig-subhead">Reels</h3>
          <div class="ig-grid">
            {videos.map((v) => (
              <div class="ig-tile fade-in">
                <InstagramEmbed url={v.url} />
              </div>
            ))}
          </div>
        </>
      )}

      {images.length > 0 && (
        <>
          <h3 class="ig-subhead">Posts</h3>
          <div class="ig-grid">
            {images.map((img) => (
              <div class="ig-tile fade-in">
                <InstagramEmbed url={img.url} />
              </div>
            ))}
          </div>
        </>
      )}

      <a class="btn btn-outline ig-cta" href={site.instagramUrl} target="_blank" rel="noopener noreferrer">
        View on Instagram
      </a>
    </div>
  </section>
)}

<script async defer src="//www.instagram.com/embed.js" is:inline></script>
<script is:inline>
  // Instagram's embed script often only fully hydrates the first blockquote when
  // several load at once (silent CDN throttling) — the rest stay stuck as static
  // "Watch on Instagram" fallbacks. Reprocessing a few times after load reliably
  // catches the stragglers without affecting embeds that already rendered fine.
  (function () {
    function reprocess() {
      if (window.instgrm && window.instgrm.Embeds) {
        window.instgrm.Embeds.process();
      }
    }
    window.addEventListener("load", reprocess);
    [1000, 2500, 4500].forEach((delay) => setTimeout(reprocess, delay));
  })();
</script>

<style>
  .instagram { background: #fff; }
  .ig-subhead {
    margin-top: var(--space-3);
    margin-bottom: var(--space-2);
    font-size: 1rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .ig-grid {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
    justify-content: center;
    align-items: start;
  }
  .ig-tile {
    display: flex;
    justify-content: center;
    overflow: hidden;
    border-radius: var(--radius-sm);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.08);
  }
  .ig-tile :global(iframe) { width: 100% !important; }
  .ig-cta { margin-top: var(--space-3); }
  @media (min-width: 700px) {
    .ig-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1100px) {
    .ig-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
