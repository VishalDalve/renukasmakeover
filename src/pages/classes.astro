---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { courses } from "../data/services";

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: courses.map((course, i) => ({
    "@type": "Course",
    position: i + 1,
    name: course.name,
    description: course.description,
    provider: { "@type": "Organization", name: site.brandName },
  })),
};
---

<BaseLayout title="Self-Makeup & Hairstyling Classes" description={`Self-makeup and hairstyling classes at ${site.brandName}.`}>
  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />

  <section class="classes-hero">
    <div class="container">
      <span class="eyebrow">Learn With Us</span>
      <h1>Self-Makeup &amp; Hairstyling Classes</h1>
      <p>From a quick crash course to a full intensive — find the batch that fits your timeline.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid grid-4">
        {courses.map((course) => (
          <div class="card fade-in">
            <h3>{course.name}</h3>
            <p class="price">{course.price}</p>
            <p>{course.description}</p>
            <a
              class="btn btn-whatsapp"
              href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent(`Hi! I'd like to enquire about the ${course.name}.`)}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              Enquire on WhatsApp
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="batch-calendar">
    <div class="container">
      <span class="eyebrow">Upcoming Batches</span>
      <h2>Live Batch Calendar</h2>
      <div class="calendar-placeholder">
        <p>
          Placeholder — embed a live booking calendar here (e.g. Cal.com) once scheduling is
          set up. For now, enquire on WhatsApp for the next available batch.
        </p>
      </div>
    </div>
  </section>

  <section class="certificates">
    <div class="container grid grid-2">
      <div class="fade-in">
        <span class="eyebrow">On Completion</span>
        <h2>Digital, QR-Verifiable Certificates</h2>
        <p>
          Every graduate receives a digital certificate with a scannable QR code linking to a
          verification page — a credential employers and clients can trust.
        </p>
      </div>
      <div class="fade-in">
        <span class="eyebrow">Community</span>
        <h2>Alumni Network</h2>
        <p>PLACEHOLDER — link to an alumni/community page once class batches are running.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .price { color: var(--color-gold); font-weight: 700; margin-bottom: var(--space-1); }
  .calendar-placeholder {
    background: #fff;
    border: 1px dashed rgba(42, 36, 32, 0.15);
    padding: var(--space-4);
    text-align: center;
  }
</style>
