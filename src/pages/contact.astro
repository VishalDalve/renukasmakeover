---
import BaseLayout from "../layouts/BaseLayout.astro";
import MapEmbed from "../components/MapEmbed.astro";
import { site } from "../data/site";
---

<BaseLayout title="Contact" description={`Get in touch with ${site.brandName} for bookings and enquiries.`}>
  <section class="contact-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Let's Talk About Your Day</h1>
      <p>WhatsApp is the fastest way to reach us — the form below is a backup.</p>
    </div>
  </section>

  <section>
    <div class="container grid grid-2">
      <div class="fade-in contact-actions">
        <a
          class="btn btn-whatsapp contact-btn"
          href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent("Hi! I'd like to enquire about a booking.")}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          Chat on WhatsApp
        </a>
        <a class="btn btn-outline contact-btn" href={`tel:${site.phone}`}>Call {site.phone}</a>
        <a class="btn btn-outline contact-btn" href={`mailto:${site.email}`}>Email Us</a>
      </div>

      <form class="fade-in contact-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="PLACEHOLDER_WEB3FORMS_ACCESS_KEY" />
        <label>
          Name
          <input type="text" name="name" required />
        </label>
        <label>
          Phone
          <input type="tel" name="phone" required />
        </label>
        <label>
          Event Date
          <input type="date" name="event_date" />
        </label>
        <label>
          Message
          <textarea name="message" rows="4" required></textarea>
        </label>
        <button class="btn btn-primary" type="submit">Send Enquiry</button>
      </form>
    </div>
  </section>

  <MapEmbed />
</BaseLayout>

<style>
  .contact-actions { display: flex; flex-direction: column; gap: var(--space-2); align-items: flex-start; }
  .contact-btn { width: 100%; justify-content: center; }
  @media (min-width: 640px) { .contact-btn { width: auto; } }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: #fff;
    padding: var(--space-3);
    border: 1px solid rgba(42, 36, 32, 0.08);
  }
  .contact-form label { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.85rem; font-weight: 600; }
  .contact-form input, .contact-form textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.6rem;
    border: 1px solid rgba(42, 36, 32, 0.2);
    border-radius: 2px;
  }
</style>
