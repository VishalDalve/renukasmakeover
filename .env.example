# Copy this file to .env and fill in real values once available.
# See SETUP.md for step-by-step instructions on obtaining each key.

# --- Instagram Graph API (Instagram Business/Creator account required) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- Google Places API (Google Cloud project required) ---
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Google Maps Embed (can reuse GOOGLE_PLACES_API_KEY if it has Maps Embed API enabled) ---
PUBLIC_GOOGLE_MAPS_EMBED_KEY=
